 namespace ZeroTier {
 
+#ifdef __OpenBSD__
+static const unsigned int ZT_OPENBSD_TAP_TRANSIENT_ERROR_LIMIT = 8;
+
+static bool ___isTransientTapReadError(int error)
+{
+	return ((error == EINTR) || (error == ETIMEDOUT) || (error == EAGAIN)
+#if EAGAIN != EWOULDBLOCK
+			|| (error == EWOULDBLOCK)
+#endif
+	);
+}
+
+static void ___logTapReaderError(const std::string& dev, const char* operation, int error, unsigned int failures, bool fatal)
+{
+	const char* description = error ? strerror(error) : "unexpected end of file";
+	const int priority = fatal ? LOG_CRIT : LOG_WARNING;
+	syslog(priority, "ZeroTier TAP reader %s failed on %s: %s (errno %d, consecutive failures %u)%s", operation, dev.c_str(), description, error, failures, fatal ? "; terminating daemon" : "; retrying");
+	fprintf(stderr, "ZeroTier TAP reader %s failed on %s: %s (errno %d, consecutive failures %u)%s" ZT_EOL_S, operation, dev.c_str(), description, error, failures, fatal ? "; terminating daemon" : "; retrying");
+}
+
+static void ___terminateForTapReaderFailure(const std::string& dev, const char* operation, int error, unsigned int failures)
+{
+	___logTapReaderError(dev, operation, error, failures, true);
+	if (::kill(::getpid(), SIGTERM) != 0)
+		::_exit(1);
+}
+
+static void ___backoffTapReader(unsigned int failures)
+{
+	const unsigned int shift = std::min(failures - 1, 6U);
+	Thread::sleep(10U << shift);
+}
+#endif
